{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information and safety preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "safetyScore": { "type": "number", "description": "Calculated safety score based on activity" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "users",
      "description": "User profile documents"
    }
  }
}
